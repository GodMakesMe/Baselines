Project_DIR="../CV_project/"
Python_ENV="../.venv312/bin/python"
CORS_ORIGINS="https://godmakesme.com,https://www.godmakesme.com,http://localhost:3000,http://127.0.0.1:3000,https://cv.godmakesme.com"

labels_dir="../../train_labels/"
vis_denoise=True
# Scripts to take inputs I will add here later

# Optional: Part 2/3 winner pipeline (checkpoint-only inference)
ENABLE_KAGGLE_SEG=False
# Ink detection now lives on its own /api/ink route + UI page — keep False here
# so it never runs as part of the surface-detection pipeline.
ENABLE_INK_DETECTION=False

# Ink-detection (TimeSformer Winner) — dedicated /api/ink route
INK_REPO_DIR="../Winner"
INK_TEST_DIR="../Ink-dataset/test"
INK_CHECKPOINT_TIMESFORMER_64="../Winner/checkpoints/timesformer_wild15_20230702185753_0_fr_i3depoch=12.ckpt"
INK_CHECKPOINT_TIMESFORMER_256="../Winner/checkpoints/wild14_deduped_64_pretrained2_20231210121321_0_fr_i3depoch=3-v2_256.ckpt"
INK_DEFAULT_MODEL="timesformer_64"
INK_DEVICE="cuda:0"
INK_START_LAYER=17
INK_NUM_LAYERS=26
INK_BATCH_SIZE=2
INK_WORKERS=2

# Optional explicit command template (leave empty to auto-detect inference_timesformer.py)
# Placeholders: {repo_dir} {input_dir} {segmentation_dir} {output_dir} {checkpoint} {device}
INK_COMMAND=""

# Inference performance tuning (tuned for 4GB VRAM — RTX 3050 Mobile)
INFERENCE_FAST_MODE=True
INFERENCE_FINAL_MAX_MODELS=1
INFERENCE_NNUNET_TILE_STEP=0.7
INFERENCE_NNUNET_NO_MIRRORING=True
INFERENCE_SKIP_LEGACY_NNUNET=True
# Skip custom U-Net on low-VRAM GPUs so the final nnU-Net has the full card.
# On 6GB+ flip this back to False to get U-Net + nnU-Net side-by-side outputs.
INFERENCE_SKIP_UNET=True