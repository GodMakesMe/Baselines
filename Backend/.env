Project_DIR="../CV_project/"
Python_ENV="../.venv312/Scripts/python.exe"
CORS_ORIGINS="https://godmakesme.com,https://www.godmakesme.com,http://localhost:3000,http://127.0.0.1:3000,https://cv.godmakesme.com"

labels_dir="../../train_labels/"
vis_denoise=True
# Scripts to take inputs I will add here later

# Optional: Part 2/3 winner pipeline (checkpoint-only inference)
ENABLE_KAGGLE_SEG=False
ENABLE_INK_DETECTION=True

# TimeSformer winner inference repo and checkpoint
# Example repo: E:/Project/Computer Vision/external/vesuvius-grandprize-winner-plus
# Example checkpoint: E:/Project/Computer Vision/external/weights/timesformer_weights.ckpt
INK_REPO_DIR="../Winner"
INK_CHECKPOINT="../Winner/checkpoints/timesformer_wild15_20230702185753_0_fr_i3depoch=12.ckpt"
INK_DEVICE="cuda:0"
INK_START_LAYER=17
INK_NUM_LAYERS=5

# Optional explicit command template (leave empty to auto-detect inference_timesformer.py)
# Placeholders: {repo_dir} {input_dir} {segmentation_dir} {output_dir} {checkpoint} {device}
INK_COMMAND=""

# Inference performance tuning
INFERENCE_FAST_MODE=True
INFERENCE_FINAL_MAX_MODELS=2
INFERENCE_NNUNET_TILE_STEP=0.7
INFERENCE_NNUNET_NO_MIRRORING=True
INFERENCE_SKIP_LEGACY_NNUNET=True